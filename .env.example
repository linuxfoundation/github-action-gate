# GitHub App credentials (from https://github.com/settings/apps)
APP_ID=
PRIVATE_KEY=
WEBHOOK_SECRET=

# GitHub OAuth — powers the "Login with GitHub" button on the dashboard.
# Copy Client ID and Client Secret from your GitHub App's settings page.
# In your GitHub App settings, add this Authorization callback URL:
#   {API_BASE_URL}/auth/github/callback  (e.g. http://localhost:3000/auth/github/callback)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# SQLite (local dev) — Prisma creates this file automatically on first migrate.
# For Cloudflare D1 (production), the DB binding is injected by the Worker
# runtime; no DATABASE_URL is needed in the Worker environment.
DATABASE_URL=file:./dev.db

# Server
PORT=3000
NODE_ENV=development

# Public URLs (used in check run messages and dashboard links)
API_BASE_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3000/dashboard

# CORS — comma-separated list of allowed origins for the REST API
# In production, set this to your GitHub Pages URL:
#   CORS_ORIGINS=https://your-org.github.io
CORS_ORIGINS=*
