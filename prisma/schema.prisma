// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// One record per repository where the app is installed and has seen activity.
model Repository {
  id             String        @id @default(cuid())
  /// GitHub's numeric repository ID (stable across renames).
  githubId       Int           @unique
  owner          String
  name           String
  /// GitHub App installation ID — used to create authenticated API requests.
  installationId Int

  // ── Gate configuration ──────────────────────────────────────────────────
  /// Whether to block or only warn when a workflow/job is unattested.
  /// Default is AUDIT (warn only). Set DEFAULT_GATE_MODE=block in .env to default to BLOCK.
  /// Stored as TEXT: "AUDIT" | "BLOCK"
  mode           String        @default("AUDIT")
  /// How many days an attestation is valid before it must be re-verified.
  expiryDays     Int           @default(180)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  attestations   Attestation[]
  workflowRuns   WorkflowRun[]

  @@unique([owner, name])
  @@index([owner])
}

/// An attestation is a vouch by a user or organization for a specific
/// workflow file, or for a named job within that workflow file.
model Attestation {
  id           String @id @default(cuid())
  repositoryId String

  /// Relative path from repo root, e.g. ".github/workflows/ci.yml"
  workflowPath String
  /// If null, the attestation covers the entire workflow file.
  /// If set, it covers only this named job within the workflow.
  jobName      String?

  // ── Voucher identity ────────────────────────────────────────────────────
  /// GitHub login of the person who created this attestation.
  voucherGithubLogin    String
  /// GitHub numeric user ID (stable across login renames).
  voucherGithubId       Int
  /// Self-reported company / organization affiliation (e.g. "AMD").
  /// Not verified — purely informational label.
  voucherOrgAffiliation String?

  // ── Tier ────────────────────────────────────────────────────────────────
  /// Stored as TEXT: "USER" | "ORGANIZATION"
  tier           String
  /// For ORGANIZATION tier: the GitHub org whose membership was verified.
  orgGithubLogin String?

  // ── Context ─────────────────────────────────────────────────────────────
  /// Free-text description of why this workflow/job is being vouched for,
  /// e.g. "rocMinductor 4xl python 3.8 nightly test suite".
  notes          String?

  // ── Lifecycle ────────────────────────────────────────────────────────────
  expiresAt  DateTime
  revokedAt  DateTime?
  /// GitHub login of whoever revoked this attestation (for audit trail).
  revokedBy  String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId, workflowPath])
  @@index([repositoryId, workflowPath, jobName])
  @@index([voucherGithubLogin])
  @@index([orgGithubLogin])
  @@index([expiresAt])
}

/// A record of each workflow run seen by the app (captured from webhook events).
/// Only the most recent 500 runs per repository are retained.
model WorkflowRun {
  id           String    @id @default(cuid())
  repositoryId String

  /// GitHub's numeric run ID, stored as a String for SQLite compatibility.
  runId        String    @unique
  /// Relative workflow file path, e.g. ".github/workflows/ci.yml"
  workflowPath String
  headBranch   String?
  headSha      String
  /// Triggering event name: "push", "pull_request", "schedule", etc.
  event        String
  /// GitHub run status: "queued" | "in_progress" | "completed"
  status       String
  /// GitHub run conclusion (null while running): "success" | "failure" | "cancelled" | "skipped" | etc.
  conclusion   String?
  /// Link to this run on GitHub.
  htmlUrl      String?

  runStartedAt DateTime?
  createdAt    DateTime  @default(now())

  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
  @@index([createdAt])
}

/// Immutable audit log for security-sensitive operations.
model AuditLog {
  id        String   @id @default(cuid())
  /// Action that was performed, e.g. "attestation.create", "attestation.revoke",
  /// "repository.config.update".
  action    String
  /// GitHub login of the user who performed the action.
  actor     String
  /// GitHub numeric user ID of the actor.
  actorId   Int
  /// JSON-encoded details of the change (new values, affected resource IDs, etc.)
  detail    String?
  /// IP address of the requester (for forensic analysis).
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([action])
  @@index([actor])
  @@index([createdAt])
}
