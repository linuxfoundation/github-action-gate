{
  "name": "github-action-gate",
  "version": "1.0.0",
  "description": "GitHub App that gates GitHub Actions workflows/jobs with ownership attestations",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "probot run ./dist/index.js",
    "dev": "tsc && probot run ./dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "d1:create": "wrangler d1 create action-gate",
    "d1:migrate:local": "wrangler d1 migrations apply action-gate --local",
    "d1:migrate:remote": "wrangler d1 migrations apply action-gate",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "@prisma/adapter-d1": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "js-yaml": "^4.1.0",
    "probot": "^13.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "wrangler": "^3.98.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0"
}
