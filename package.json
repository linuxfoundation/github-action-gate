{
  "name": "github-action-gate",
  "version": "1.0.0",
  "description": "GitHub App that gates GitHub Actions workflows/jobs with ownership attestations",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.worker.json",
    "start": "probot run ./dist/index.js",
    "dev": "tsc && probot run ./dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "d1:create": "wrangler d1 create action-gate",
    "d1:migrate:local": "wrangler d1 migrations apply action-gate --local",
    "d1:migrate:remote": "wrangler d1 migrations apply action-gate",
    "type-check": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'docs/app.js'",
    "format:check": "prettier --check 'src/**/*.ts' 'docs/app.js'",
    "test": "jest --passWithNoTests",
    "pages:deploy": "wrangler pages deploy docs --project-name action-gate-dashboard"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/rest": "^21.0.2",
    "@prisma/adapter-d1": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.1",
    "js-yaml": "^4.1.0",
    "pino": "^10.3.1",
    "probot": "^13.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.0",
    "wrangler": "^3.98.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0"
}
